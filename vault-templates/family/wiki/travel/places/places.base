# Places (POIs) — point-of-interest catalog rendered by Obsidian Bases.

filters:
  and:
    - 'note.type == "poi"'
    - 'note.status != "closed"'

views:
  - type: cards
    name: By Location
    groupBy:
      property: location
      direction: ASC
    order:
      - title

  - type: cards
    name: By Kind
    groupBy:
      property: kind
      direction: ASC
    order:
      - title

  - type: table
    name: All POIs
    order:
      - title
      - location
      - neighborhood
      - kind
      - duration
      - visited

  - type: cards
    name: Wishlist (Not Yet Visited)
    filters:
      and:
        - 'note.visited == false'
    order:
      - title

  - type: table
    name: Visited (Past Trips)
    filters:
      and:
        - 'note.visited == true'
    order:
      - visit_date
      - title
