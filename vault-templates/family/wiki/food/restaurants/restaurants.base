# Restaurants — multi-view inventory rendered by Obsidian Bases.
# Filters: only active or wishlist restaurants (excludes 'closed').
# New restaurant entries auto-appear via the type: restaurant filter.

filters:
  and:
    - 'note.type == "restaurant"'
    - 'note.status != "closed"'

views:
  - type: cards
    name: By Cuisine
    groupBy:
      property: cuisine
      direction: ASC
    order:
      - title
      - family_rating

  - type: table
    name: All Restaurants
    order:
      - title
      - cuisine
      - price_tier
      - location
      - family_rating
      - last_visited

  - type: table
    name: Recent Visits
    order:
      - last_visited
      - title

  - type: cards
    name: Wishlist
    filters:
      and:
        - 'note.status == "wishlist"'
    order:
      - title
