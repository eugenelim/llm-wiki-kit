# Subscriptions — multi-view inventory rendered by Obsidian Bases.
# Filters: only active subscriptions (excludes cancelled).

filters:
  and:
    - 'note.type == "subscription"'
    - 'note.status != "cancelled"'

views:
  - type: cards
    name: By Category
    groupBy:
      property: category
      direction: ASC
    order:
      - title
      - amount

  - type: table
    name: All Subscriptions
    order:
      - title
      - category
      - provider
      - amount
      - billing_cycle
      - next_billing
      - account_holder

  - type: table
    name: Coming Up for Renewal
    order:
      - next_billing
      - title

  - type: table
    name: Due for Re-evaluation
    order:
      - review_by
      - title

  - type: cards
    name: Annual vs Monthly
    groupBy:
      property: billing_cycle
      direction: ASC
    order:
      - title
      - amount
