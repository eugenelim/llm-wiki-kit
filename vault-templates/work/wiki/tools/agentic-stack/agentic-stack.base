# Agentic Stack — multi-view inventory of cloud tooling rendered by Obsidian Bases.
# Filters: only in-use or evaluating tools (excludes rejected, deprecated).

filters:
  and:
    - 'note.type == "cloud-tool"'
    - 'note.status != "rejected"'

views:
  - type: cards
    name: By Cloud Provider
    groupBy:
      property: cloud_provider
      direction: ASC
    order:
      - title

  - type: cards
    name: By Role in Stack
    groupBy:
      property: role
      direction: ASC
    order:
      - title

  - type: table
    name: All Tools
    order:
      - title
      - cloud_provider
      - role
      - install_status
      - pricing
      - maintainer

  - type: cards
    name: In Production
    filters:
      and:
        - 'note.install_status == "production"'
    order:
      - title

  - type: cards
    name: Currently Evaluating
    filters:
      and:
        - 'note.status == "evaluating"'
    order:
      - title
