# SaaS / Vendor Registry — multi-view inventory rendered by Obsidian Bases.
# Filters: active and up-for-renewal contracts (excludes cancelled).

filters:
  and:
    - 'note.type == "saas-contract"'
    - 'note.status != "cancelled"'

views:
  - type: cards
    name: By Category
    groupBy:
      property: category
      direction: ASC
    order:
      - title

  - type: table
    name: Up for Renewal
    order:
      - renewal_date
      - title

  - type: table
    name: All Contracts
    order:
      - title
      - category
      - vendor
      - amount
      - billing_cycle
      - renewal_date
      - seats
      - account_owner

  - type: cards
    name: By Account Owner
    groupBy:
      property: account_owner
      direction: ASC
    order:
      - title

  - type: table
    name: Annual Spend by Category
    groupBy:
      property: category
      direction: ASC
    order:
      - title
      - amount
    summaries:
      amount: Sum
