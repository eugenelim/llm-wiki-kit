# SaaS / Vendor Registry — multi-view inventory rendered by Obsidian Bases.
# Filters: active and up-for-renewal contracts (excludes cancelled).

filter:
  - property: type
    operator: is
    value: saas-contract
  - property: status
    operator: not
    value: cancelled

views:
  - name: By Category
    type: card
    group_by: category
    order:
      - property: title

  - name: Up for Renewal
    type: table
    order:
      - property: renewal_date
        descending: false
      - property: title

  - name: All Contracts
    type: table
    order:
      - property: title
      - property: category
      - property: vendor
      - property: amount
      - property: billing_cycle
      - property: renewal_date
      - property: seats
      - property: account_owner

  - name: By Account Owner
    type: card
    group_by: account_owner
    order:
      - property: title

  - name: Annual Spend by Category
    type: table
    group_by: category
    order:
      - property: amount
        descending: true
