# Bookmark Homepage — multi-view dashboard rendered by Obsidian Bases.
# Filters: only active bookmarks (type: bookmark, status: active).
# Add new bookmarks by creating type: bookmark pages in wiki/bookmarks/;
# they appear here automatically.

filter:
  - property: type
    operator: is
    value: bookmark
  - property: status
    operator: is
    value: active

views:
  - name: By Category
    type: card
    group_by: category
    order:
      - property: title
      - property: last_visited
        descending: true

  - name: All Bookmarks
    type: table
    order:
      - property: title
      - property: category
      - property: url
      - property: last_visited
      - property: tags

  - name: Daily Drivers
    type: card
    filter:
      - property: category
        operator: is
        value: daily-tools
    order:
      - property: title

  - name: Reference
    type: card
    filter:
      - property: category
        operator: is
        value: reference
    order:
      - property: title
