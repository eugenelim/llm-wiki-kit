# Tooling — multi-view inventory rendered by Obsidian Bases.

filters:
  and:
    - 'note.type == "tooling-entry"'
    - 'note.status != "dropped"'

views:
  - type: cards
    name: By Role
    groupBy:
      property: role
      direction: ASC
    order:
      - title

  - type: table
    name: All Tools
    order:
      - title
      - role
      - how_used
      - cost
      - status
      - adoption_date

  - type: cards
    name: Daily Drivers
    filters:
      and:
        - 'note.how_used == "daily-driver"'
    order:
      - title

  - type: cards
    name: Currently Evaluating
    filters:
      and:
        - 'note.status == "evaluating"'
    order:
      - title

  - type: table
    name: Due for Re-evaluation
    order:
      - last_evaluated
      - title
