# Canonical exercises with current PRs and last-session breadcrumb.

filters:
  and:
    - file.hasTag("exercise")
    - file.hasProperty("modality")

views:
  - type: cards
    name: By Movement Pattern
    groupBy:
      property: movement_pattern
      direction: ASC
    order:
      - title
      - modality
      - pr_estimated_1rm
      - pr_set_summary
      - last_session

  - type: table
    name: All Exercises
    order:
      - title
      - movement_pattern
      - modality
      - pr_estimated_1rm
      - pr_set_summary
      - last_session
      - sessions_count

  - type: cards
    name: Stale (no session in 30+ days)
    filters:
      and:
        - 'note.last_session < now() - "30d"'
    groupBy:
      property: movement_pattern
      direction: ASC
    order:
      - title
      - modality
      - last_session
      - pr_set_summary
