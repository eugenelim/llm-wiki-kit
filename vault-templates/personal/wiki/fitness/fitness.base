# Fitness dashboard — sessions, programs, exercises, body metrics.
# Aggregates four page-types tagged in the fitness ontology.

filters:
  or:
    - file.hasTag("fitness-session")
    - file.hasTag("fitness-program")
    - file.hasTag("body-metric")
    - file.hasTag("exercise")

views:
  - type: cards
    name: Recent Sessions (last 30 days)
    filters:
      and:
        - file.hasTag("fitness-session")
        - 'note.date >= now() - "30d"'
    groupBy:
      property: session_type
      direction: ASC
    order:
      - title
      - date
      - session_type
      - focus
      - duration_min
      - rpe
      - prs_set

  - type: table
    name: All Sessions
    filters:
      and:
        - file.hasTag("fitness-session")
    order:
      - title
      - date
      - session_type
      - focus
      - duration_min
      - rpe
      - program

  - type: cards
    name: Active Programs
    filters:
      and:
        - file.hasTag("fitness-program")
        - 'note.status == "active"'
    order:
      - title
      - goal
      - current_mesocycle
      - current_microcycle
      - period

  - type: table
    name: Body Metrics — Last Year
    filters:
      and:
        - file.hasTag("body-metric")
        - 'note.date >= now() - "365d"'
    order:
      - title
      - date
      - weight_lbs
      - body_fat_pct
      - sleep_avg_last_7d

  - type: cards
    name: PR Dashboard (Strength)
    filters:
      and:
        - file.hasTag("exercise")
        - '["barbell", "dumbbell", "machine", "kettlebell", "bodyweight"].contains(modality)'
    groupBy:
      property: movement_pattern
      direction: ASC
    order:
      - title
      - movement_pattern
      - modality
      - pr_estimated_1rm
      - pr_set_summary
      - last_session
      - sessions_count

  - type: cards
    name: This Week
    filters:
      and:
        - file.hasTag("fitness-session")
        - 'note.date >= now() - "7d"'
    order:
      - title
      - date
      - session_type
      - focus
      - duration_min
      - rpe
