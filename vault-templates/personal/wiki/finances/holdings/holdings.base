# Holdings — investment portfolio inventory rendered by Obsidian Bases.
# Filters: active and partial-sold (excludes fully-sold).

filters:
  and:
    - 'note.type == "holding"'
    - 'note.status != "sold"'

views:
  - type: cards
    name: By Broker
    groupBy:
      property: broker
      direction: ASC
    order:
      - title

  - type: cards
    name: By Asset Class
    groupBy:
      property: asset_class
      direction: ASC
    order:
      - title

  - type: cards
    name: By Account Type
    groupBy:
      property: account_type
      direction: ASC
    order:
      - title

  - type: table
    name: All Holdings
    order:
      - title
      - ticker
      - asset_class
      - broker
      - account_type
      - shares
      - cost_basis
      - acquired

  - type: table
    name: Due for Review
    order:
      - last_review
      - title
