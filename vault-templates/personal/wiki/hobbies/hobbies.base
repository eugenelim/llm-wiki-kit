# Hobbies + sessions dashboard.
# One overview per hobby plus a recent-sessions roll-up.

filters:
  or:
    - and:
        - file.hasTag("hobby")
        - file.hasProperty("category")
    - file.hasTag("hobby-session")

views:
  - type: cards
    name: Active Hobbies by Category
    filters:
      and:
        - file.hasTag("hobby")
        - 'note.status == "active"'
    groupBy:
      property: category
      direction: ASC
    order:
      - title
      - current_focus
      - next_milestone
      - modified

  - type: table
    name: All Hobbies
    filters:
      and:
        - file.hasTag("hobby")
    order:
      - title
      - category
      - status
      - current_focus
      - modified
      - started

  - type: cards
    name: Needs Attention (active, no session in 30 days)
    filters:
      and:
        - file.hasTag("hobby")
        - 'note.status == "active"'
        - 'note.modified < now() - "30d"'
    groupBy:
      property: category
      direction: ASC
    order:
      - title
      - current_focus
      - modified

  - type: table
    name: Dormant Hobbies
    filters:
      and:
        - file.hasTag("hobby")
        - 'note.status == "dormant"'
    order:
      - title
      - category
      - started
      - modified

  - type: cards
    name: Recent Sessions (last 30 days)
    filters:
      and:
        - file.hasTag("hobby-session")
        - 'note.date >= now() - "30d"'
    groupBy:
      property: hobby
      direction: ASC
    order:
      - title
      - hobby
      - date
      - focus
      - duration_min
      - mood
