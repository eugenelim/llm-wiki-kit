# Advisors / Mentors — multi-view inventory rendered by Obsidian Bases.

filters:
  and:
    - 'note.type == "advisor"'
    - 'note.status != "mentor-graduated"'

views:
  - type: cards
    name: By Relationship
    groupBy:
      property: relationship
      direction: ASC
    order:
      - title

  - type: table
    name: All Advisors
    order:
      - title
      - relationship
      - company
      - role
      - contact_cadence
      - last_contact

  - type: table
    name: Stale Connections
    order:
      - last_contact
      - title

  - type: cards
    name: Active Mentorships
    filters:
      and:
        - 'note.status == "active"'
    order:
      - contact_cadence
      - title
