# Accomplishment ledger — append-the-moment wins across 10 dimensions.
# Quarterly + annual reviews compose per-dimension reflections from these.

filters:
  and:
    - file.hasTag("accomplishment")
    - file.hasProperty("dimension")

views:
  - type: cards
    name: By Dimension
    groupBy:
      property: dimension
      direction: ASC
    order:
      - title
      - date
      - impact
      - evidence

  - type: table
    name: All Accomplishments
    order:
      - title
      - dimension
      - date
      - impact
      - status
      - related_project

  - type: cards
    name: This Year — Significant+
    filters:
      and:
        - 'date(note.date) >= date("2026-01-01")'
        - '["significant", "major"].contains(impact)'
    groupBy:
      property: dimension
      direction: ASC
    order:
      - title
      - dimension
      - date
      - evidence

  - type: cards
    name: Career
    filters:
      and:
        - 'note.dimension == "career"'
    order:
      - title
      - date
      - impact
      - evidence

  - type: cards
    name: Craft
    filters:
      and:
        - 'note.dimension == "craft"'
    order:
      - title
      - date
      - impact
      - evidence

  - type: cards
    name: Learning
    filters:
      and:
        - 'note.dimension == "learning"'
    order:
      - title
      - date
      - impact
      - evidence
