# Bookmark Homepage — multi-view dashboard rendered by Obsidian Bases.
# Filters: only active bookmarks (type: bookmark, status: active).
# Add new bookmarks by creating type: bookmark pages in wiki/bookmarks/;
# they appear here automatically.

filters:
  and:
    - 'note.type == "bookmark"'
    - 'note.status == "active"'

views:
  - type: cards
    name: By Category
    groupBy:
      property: category
      direction: ASC
    order:
      - title
      - last_visited

  - type: table
    name: All Bookmarks
    order:
      - title
      - category
      - url
      - last_visited
      - tags

  - type: cards
    name: Daily Drivers
    filters:
      and:
        - 'note.category == "daily-tools"'
    order:
      - title

  - type: cards
    name: Reading
    filters:
      and:
        - 'note.category == "reading"'
    order:
      - title

  - type: cards
    name: Career Tools
    filters:
      and:
        - 'note.category == "career-tools"'
    order:
      - title
