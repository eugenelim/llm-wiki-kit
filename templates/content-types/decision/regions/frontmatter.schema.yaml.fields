  decision_date:
    type: date
    format: YYYY-MM-DD
    when: subtype == decision-record
  decision_owner:
    type: string
    when: subtype == decision-record
  decision_status:
    type: string
    when: subtype == decision-record
  decision_context:
    type: string
    optional: true
    when: subtype == decision-record
  decision_alternatives:
    type: list
    items: string
    optional: true
    when: subtype == decision-record
  decision_supersedes:
    type: string
    optional: true
    when: subtype == decision-record
