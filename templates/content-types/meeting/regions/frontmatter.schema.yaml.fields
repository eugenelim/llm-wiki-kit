  meeting_date:
    type: date
    format: YYYY-MM-DD
    when: subtype == meeting
  meeting_attendees:
    type: list
    items: string
    when: subtype == meeting
  meeting_decisions:
    type: list
    items: string
    optional: true
    when: subtype == meeting
  meeting_follow_ups:
    type: list
    items: string
    optional: true
    when: subtype == meeting
