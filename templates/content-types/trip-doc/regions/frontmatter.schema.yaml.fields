  trip_destination:
    type: string
    when: subtype == trip
  trip_start_date:
    type: date
    format: YYYY-MM-DD
    when: subtype == trip
  trip_end_date:
    type: date
    format: YYYY-MM-DD
    when: subtype == trip
  trip_travelers:
    type: list
    items: string
    when: subtype == trip
  trip_status:
    type: string
    when: subtype == trip
